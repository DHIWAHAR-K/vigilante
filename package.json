{
  "name": "vigilante",
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "dev": "pnpm --filter web tauri:dev",
    "start": "pnpm --filter web tauri:dev",
    "desktop:dev": "pnpm --filter web tauri:dev",
    "desktop:build": "pnpm --filter web tauri:build",
    "dev:orchestrator": "pnpm --filter @vigilante/orchestrator dev",
    "build": "pnpm --filter web tauri:build",
    "typecheck": "turbo typecheck",
    "lint": "pnpm run typecheck"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "^5.8.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ]
  },
  "packageManager": "pnpm@10.7.0"
}
