{
  "name": "vigilante",
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "vigilante": "node packages/cli/bin/vigilante.mjs",
    "vigilante:dev": "node packages/cli/bin/vigilante.mjs --dev",
    "dev": "node packages/cli/bin/vigilante.mjs --dev",
    "start": "node packages/cli/bin/vigilante.mjs",
    "dev:orchestrator": "pnpm --filter @vigilante/orchestrator dev",
    "dev:web": "pnpm --filter web dev",
    "build": "turbo build",
    "typecheck": "turbo typecheck",
    "lint": "pnpm run typecheck"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "^5.8.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ]
  },
  "packageManager": "pnpm@10.7.0"
}
